{% extends 'base.html.twig' %}

{% block title %}{{ article.title }}{% endblock %}

{% block body %}
    <div class="container mt-4 mb-5">
        {# Article Header #}
        <div class="article-header">
            <div class="container">
                <h1>{{ article.title }}</h1>

                <div class="article-meta">
                <span>
                    {{ article.createdAt|date('F d, Y') }}
                </span>
                    <span>
                    {{ article.createdAt|date('H:i') }}
                </span>
                </div>
                <div class="action-buttons mt-3">
                    {% if is_granted('ARTICLE_EDIT', article) %}
                        <a href="{{ path('app_article_edit', {'id': article.id}) }}" class="btn btn-warning">
                            Edit
                        </a>
                    {% endif %}
                    {% if is_granted('ARTICLE_DELETE', article) %}
                        <form method="post" action="{{ path('app_article_delete', {'id': article.id}) }}"
                              style="display: inline-block;"
                              onsubmit="return confirm('Are you sure you want to delete this article?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ article.id) }}">
                            <button class="btn btn-danger">
                                Delete
                            </button>
                        </form>
                    {% endif %}
                    {# Article Info #}
                    {% if is_granted('ARTICLE_EDIT', article) %}
                        <div class="card mt-3">
                            <div class="card-body">
                                <h5>Article Information</h5>
                                <table class="table table-sm">
                                    <tbody>
                                    <tr>
                                        <th style="width: 150px;">Slug:</th>
                                        <td><code>{{ article.slug }}</code></td>
                                    </tr>
                                    <tr>
                                        <th>Created:</th>
                                        <td>{{ article.createdAt|date('Y-m-d H:i:s') }}</td>
                                    </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    {% endif %}
                    <a href="{{ path('app_article_index') }}" class="btn btn-outline-light">
                        Back to List
                    </a>
                </div>

                {% if article.coverImage %}
                    <img src="{{ asset('uploads/articles/' ~ article.coverImage) }}"
                         alt="{{ article.title }}"
                         class="article-cover-image mt-3">
                {% endif %}
            </div>
        </div>

        {# Article Content #}
        <div class="row">
            <div class="col-lg-8">
                <div class="card-body">
                    <div class="article-content">
                        {{ article.content|raw }}
                    </div>
                    {{ include('article/_comment.html.twig') }}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
