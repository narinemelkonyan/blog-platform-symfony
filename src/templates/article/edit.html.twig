{% extends 'base.html.twig' %}

{% block title %}Update Article{% endblock %}

{% block body %}
    <div class="container mt-5 mb-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card">
                    <div class="card-header">
                        <h3 class="mb-0">
                             Edit Article
                        </h3>
                    </div>
                    <div class="card-body">
                        {{ form_start(form, {
                            'attr': {
                                'enctype': 'multipart/form-data',
                                'data-controller': 'autosave',
                                'data-autosave-update-url-value': path('app_article_draft_update', {'id': article.id}),
                            }
                        }) }}
                        {{ form_errors(form) }}

                        <div class="mb-4">
                            {{ form_label(form.title, null, {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(form.title, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.title) }}
                        </div>

                        <div class="mb-4">
                            {{ form_label(form.content, null, {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(form.content, {'attr': {'class': 'form-control', 'rows': 10}}) }}
                            {{ form_errors(form.content) }}
                        </div>

                        <div class="mb-4">
                            {{ form_label(form.coverImage, null, {'label_attr': {'class': 'form-label'}}) }}
                            {% if article.coverImage %}
                                <div class="mb-2">
                                    <img src="{{ asset('uploads/articles/' ~ article.coverImage) }}"
                                         alt="Current cover"
                                         style="max-height: 150px;">
                                    <small class="text-muted d-block">Upload new image to replace</small>
                                </div>
                            {% endif %}
                            {{ form_widget(form.coverImage, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.coverImage) }}
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" name="action" value="published" class="btn btn-primary">Update Article</button>
                            <button type="submit" name="action" value="draft" class="btn btn-warning">
                                Save as Draft
                            </button>
                            <a href="{{ path('app_article_view', {'id': article.id}) }}" class="btn btn-outline-secondary">
                                Cancel
                            </a>
                        </div>

                        {{ form_end(form) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
