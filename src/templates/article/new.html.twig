{% extends 'base.html.twig' %}

{% block title %}Create New Article{% endblock %}

{% block body %}
    <div class="container mt-5 mb-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card">
                    <div class="card-header">
                        <h3 class="mb-0">
                            Create New Article
                        </h3>
                    </div>
                    <div class="card-body">
                        {{ form_start(form, {
                            'attr': {
                                'data-controller': 'autosave',
                                'data-autosave-save-url-value': path('app_article_draft_new'),
                            }
                        })
                        }}
                        {{ form_errors(form) }}

                        <div class="mb-4">
                            <span data-autosave-target="status" class="autosave-status text-muted"></span>
                        </div>

                        <div class="mb-4">
                            {{ form_label(form.title, null, {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(form.title, {'attr': {'class': 'form-control', 'data-autosave-target': 'title'}}) }}
                            {{ form_errors(form.title) }}
                        </div>

                        <div class="mb-4">
                            {{ form_label(form.content, null, {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(form.content, {'attr': {'class': 'form-control', 'rows': 10, 'data-autosave-target': 'content'}}) }}
                            {{ form_errors(form.content) }}
                        </div>

                        <div class="mb-4">
                            {{ form_label(form.coverImage, null, {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(form.coverImage, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.coverImage) }}
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" name="action" value="published"  class="btn btn-primary">
                                Publish Article
                            </button>
                            <button type="submit" name="action" value="draft" class="btn btn-warning">
                                Save as Draft
                            </button>
                            <a href="{{ path('app_article_index') }}" class="btn btn-outline-secondary">
                                 Cancel
                            </a>
                        </div>

                        {{ form_end(form) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
