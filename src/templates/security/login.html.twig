{% extends 'base.html.twig' %}

{% block title %}Log In - Article Manager{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/login.css') }}">
{% endblock %}

{% block body %}
    <div class="login-wrapper">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-md-6 col-lg-5 col-xl-4">
                    <div class="text-center mb-4">
                        <p class="login-subtitle">Sign in to continue</p>
                    </div>
                    <div class="card login-card">
                        <div class="card-body">
                            {{ form_start(form, {
                                'action': path('app_login'),
                                'method': 'POST',
                                'attr': {'class': 'login-form'}
                            }) }}
                            <div class="mb-3">
                                {{ form_label(form.email) }}
                                {{ form_widget(form.email) }}
                                {{ form_errors(form.email) }}
                            </div>
                            <div >
                                {{ form_label(form.password) }}
                                {{ form_widget(form.password) }}
                                {{ form_errors(form.password) }}
                            </div>
                            {% if error %}
                                <div class="error-message">
                                    {{ error.messageKey | trans(error.messageData, 'security') }}
                                </div>
                            {% endif %}
                            <div class="d-flex justify-content-between align-items-center mt-4">
                                <button type="submit" class="btn btn-primary">Sign In</button>
                                <a href="{{ url( 'app_password_reset_request' ) }}" class="reset-link">Reset password</a>
                            </div>
                            <div class="form-check mt-3">
                                {{ form_widget(form.remember_me) }}
                                {{ form_label(form.remember_me) }}
                            </div>
                            {{ form_end(form) }}
                        </div>
                    </div>
                    <div class="text-center mt-4">
                        <p class="register-link mb-0">
                            Don't have an account?
                            <a href="{{ url( 'app_register' ) }}">Create one</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
