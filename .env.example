# Database Configuration
DB_NAME=symfony
DB_USER=symfony
DB_PASSWORD=symfony
DB_ROOT_PASSWORD=root
DB_PORT=3306
DB_HOST=mysql
DB_VERSION=8.4

# Docker User Configuration (используется только в development stage)
USER_UID=1000
USER_GID=1000

# Base / Default Ports
NGINX_PORT=8080
MYSQL_PORT=3307

# Development Ports (отличаются от базовых — нет конфликта при одновременном запуске)
NGINX_PORT_DEV=8081
MYSQL_PORT_DEV=3308

# Production Ports
NGINX_PORT_PROD=80
# MySQL в prod не публикуется — MYSQL_PORT_PROD не нужен

# Logging Configuration
LOG_MAX_SIZE=10m
LOG_MAX_FILES=3
LOG_MAX_SIZE_PROD=50m
LOG_MAX_FILES_PROD=5

# Symfony Application Configuration
APP_ENV=dev
APP_SECRET=devsecret123456789012345678901234

# Database
DATABASE_URL=mysql://symfony:symfony@mysql:3306/symfony?serverVersion=8.4

# Mailer
MAILER_DSN=gmail+smtp://your_email@gmail.com:your_app_password@default
MAILER_FROM=your_email@gmail.com

# Redis
REDIS_PORT=6379
REDIS_DSN=redis://symfony-redis:6379

http://localhost:8080

TINYMCE_API_KEY=YOUR_API_KEY
